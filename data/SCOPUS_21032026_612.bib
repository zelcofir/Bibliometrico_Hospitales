@ARTICLE{Quispe2024,
	author = {Quispe, Guiovanna and Loza, Cesar and Limaco, Luis and Gallegos, Ruth and Palomino, Carlos and Cruz, Ivett and Miranda, Jacqueline and Rodriguez, Liliana and Husøy, Andreas and Steiner, Timothy J},
	title = {The prevalence and demographic associations of headache in the adult population of Peru: a national cross-sectional population-based study},
