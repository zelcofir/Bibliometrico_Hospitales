@ARTICLE{Pereyra20261,
	author = {Pereyra, Wilson and Ballena, Jorge and Failoc-Rojas, Virgilio E. and Vásquez, Bruno and Zavala, Rocío and Rivadeneyra, José and Carcasi, Edgar and Ramos, Juan and Villegas, Francisco and Mamani, Roy and Ferrer, Diosdado and Ríos, Estuardo and Zambrano, William and Villar, Wilmar and Murrieta, Guido and Paz, Manuel and Garnique, Emilio},
