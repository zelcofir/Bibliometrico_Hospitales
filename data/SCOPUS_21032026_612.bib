@ARTICLE{Grandjean20111164,
	author = {Grandjean, Louis and Crossa, A. and Gilman, R.H. and Herrera, C. and Bonilla, C. and Jave, O. and Cabrera, J.L. and Martin, L. and Escombe, A.R. and Moore, D.A.J.},
	title = {Tuberculosis in household contacts of multidrug-resistant tuberculosis patients},
	year = {2011},
	journal = {International Journal of Tuberculosis and Lung Disease},
	volume = {15},
	number = {9},
	pages = {1164 - 1169},
	doi = {10.5588/ijtld.11.0030},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-80051696220&doi=10.5588%2Fijtld.11.0030&partnerID=40&md5=87fad1d1606b146ad021774b3a76a23a},
	affiliations = {Wellcome Centre for Clinical Tropical Medicine, Wright Fleming Institute, Imperial College London, London W2 1PG, Norfolk Place, United Kingdom; Departamento de Microbiología, Facultad de Ciencias, Universidad Peruana Cayetano Heredia, Lima, Peru; Unidad Técnica de Tuberculosis MDR, Lima, Peru; Socios en Salud Peru (Partners in Health), Boston, MA, United States; Department of International Health, Johns Hopkins Bloomberg School of Public Health, Baltimore, MD, United States; Asociación Benefica Prisma, Lima, Peru; Hospital Nacional Daniel Alcides Carrion, Callao, Lima, Peru; London School of Hygiene and Tropical Medicine, London, United Kingdom},
	abstract = {SETTING: The burden of tuberculosis (TB) disease among household contacts of multidrug-resistant TB (MDR-TB) patients is poorly understood and might represent a target for transmission-interrupting interventions. DESIGN: This retrospective cohort study, conducted in Lima, Peru, from June to September 2008, estimated the incidence of TB disease among household contacts of MDR-TB patients in 358 households. RESULTS: Of 2112 household contacts in 80 households (22% of households), 108 (5%) developed TB disease during the study, giving an incidence rate of 2360 per 100 000 contact follow-up years for each of the fi rst 3 years after exposure. Drug susceptibility tests (DST) were available for 50 diseased contacts, of whom 36 (80%) had MDR-TB. Forty-two pairs of index-contact DSTs were available, among which the contact had an identical or less resistant phenotype than the index case in 27 pairs. Multivariate Cox regression demonstrated that male contacts (hazard ratio [HR] 2.8, P < 0.05), with previous TB disease (HR 20.7, P < 0.001) and with associated (non-human immunodefi ciency virus) comorbidities (HR 11.2, P < 0.001) were more likely to develop TB. CONCLUSION: The high percentage of diseased household contacts highlights an opportunity for householdlevel interventions to prevent transmission, whether or not these cases were all attributable to the index case. © 2011 The Union.},
	author_keywords = {Household contacts; Incidence; Multidrug-resistant; Tuberculosis},
	keywords = {Adolescent; Adult; Antitubercular Agents; Cohort Studies; Cost of Illness; Family Characteristics; Female; Follow-Up Studies; Humans; Incidence; Male; Microbial Sensitivity Tests; Multivariate Analysis; Peru; Proportional Hazards Models; Retrospective Studies; Tuberculosis, Multidrug-Resistant; Young Adult; ethambutol; isoniazid; rifampicin; streptomycin; adolescent; adult; aged; antibiotic resistance; article; asthma; bacterial transmission; child; chronic obstructive lung disease; comorbidity; contact examination; controlled study; diabetes mellitus; disease association; female; follow up; household; human; incidence; infant; infection risk; major clinical study; male; multidrug resistant tuberculosis; Peru; phenotype; priority journal; retrospective study; risk assessment; risk factor; school child; sex difference; sputum culture; sputum smear; survival rate; tuberculosis},
	correspondence_address = {L. Grandjean; Wellcome Centre for Clinical Tropical Medicine, Wright Fleming Institute, Imperial College London, London W2 1PG, Norfolk Place, United Kingdom; email: drlouisgrandjean@hotmail.com},
