}

@ARTICLE{Alvarez202594,
	author = {Alvarez, Karla Lucia F. and Ortiz-Manrique, Michelle M. and Davila-Del-Carpio, Gonzalo and Peralta-Mestas, Antero and Lino Cardenas, Christian L.},
	title = {Profiling the metabolome of older adults who live with overweight/obesity and undiagnosed cognitive impairment},
	year = {2025},
	journal = {Neuroscience},
	volume = {582},
	pages = {94 - 103},
	doi = {10.1016/j.neuroscience.2025.07.037},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105011292614&doi=10.1016%2Fj.neuroscience.2025.07.037&partnerID=40&md5=6befd1dfc21bad376a7fb75d8249ec09},
	affiliations = {Laboratory of Genomics and Neurovascular Diseases, Universidad Católica de Santa María, Arequipa, Peru; Vice Rectorate for Research, Universidad Católica de Santa María, Arequipa, Peru; Division of Neurology, Psychiatry and Radiology of the National Hospital ESSALUD, HNCASE, Arequipa, Peru; Cardiovascular Research Center, Cardiology Division, Massachusetts General Hospital, Boston, United States},
	abstract = {Cognitive impairment (CI), ranging from mild impairment to dementia, is highly undiagnosed in the elderly population. In this population, the association between anthropometric parameters [waist circumference (WC) and body mass index (BMI)] and CI is uncertain. Additionally, it is unknown whether peripheral metabolic alterations associated with cognitive dysfunction are present in older adults who are unaware of their CI diagnosis. The objective of this study was to fill these gaps by recruiting 29 older Peruvian adults who reported being in good mental and physical health to evaluate their cognitive functions, anthropometric characteristics, and metabolomic profile. Based on cognitive tests (MoCA test and Clock Drawing test), participants were assigned to either the CI (n = 15) or control group (n = 12), and their peripheral plasma metabolic profiles were assessed through LC-mass spectrometry untargeted analysis. We found that high WC and BMI were associated with CI. Remarkably, participants in the CI group exhibited a perturbed metabolism of ergothioneine, 3-methyluridine, and the sphingolipid pathway. Supporting the relevance of these alterations to cognitive dysfunction, similar metabolic disturbances were observed in a cohort of patients previously diagnosed with severe CI (dementia, n = 8). Thus, high BMI and WC are associated with CI, and a peripheral metabolic signature linked to dementia is present in older adults who were living with undiagnosed CI. Revealing the mechanisms that regulate these metabolites may help comprehend the pathophysiology of dementia. Moreover, given the global rise in obesity, our study highlights a public health concern that could be mirrored in other countries. © 2025 International Brain Research Organization (IBRO)},
