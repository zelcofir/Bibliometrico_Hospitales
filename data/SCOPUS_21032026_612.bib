@CONFERENCE{Apaza Veliz2016,
	author = {Apaza Veliz, D.G. and Herrera Vera, R.D. and Cardenas Abarca, C.A. and Oporto Gonzales, C.A. and Aguilar Ramírez, C. and Vega Ramírez, J.L. and Urquizo Baldomero, R.M.},
