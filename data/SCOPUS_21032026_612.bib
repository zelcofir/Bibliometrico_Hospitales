@ARTICLE{Gimbrone20171851,
	author = {Gimbrone, Nicholas T. and Sarcar, Bhaswati and Gordian, Edna R. and Rivera, Jason I. and Lopez, Christian and Yoder, Sean J. and Teer, Jamie K. and Welsh, Eric A. and Chiappori, Alberto A. and Schabath, Matthew B. and Reuther, Gary W. and Dutil, Julie and Garcia, Miosotis and Ventosilla-Villanueva, Ronald and Vera-Valdivia, Luis and Yabar-Berrocal, Alejandro and Motta-Guerrero, Rodrigo and Santiago-Cardona, Pedro G. and Muñoz-Antonia, Teresita and Cress, W. Douglas},
	title = {Somatic Mutations and Ancestry Markers in Hispanic Lung Cancer Patients},
	year = {2017},
	journal = {Journal of Thoracic Oncology},
