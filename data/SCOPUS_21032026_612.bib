@ARTICLE{Valladares-Garrido2023,
	author = {Valladares-Garrido, Mario J. and Picón-Reátegui, Cinthia Karina and Zila-Velasque, J. Pierre and Grados-Espinoza, Pamela and Vera-Ponce, Víctor J. and Pereira-Victorio, César Johan and Valladares-Garrido, Danai and Failoc-Rojas, Virgilio E.},
	title = {Depression and anxiety in peruvian military personnel during the pandemic context: a cross-sectional study},
