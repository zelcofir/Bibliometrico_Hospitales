	correspondence_address = {M. Hueda-Zavaleta; Facultad de Ciencias de la Salud, Universidad Privada de Tacna, Tacna, Peru; email: miguelhueda90@gmail.com; V.A. Benites-Zapata; Unidad de Investigación para la Generación y Síntesis de Evidencias en Salud, Universidad San Ignacio de Loyola, Lima, Peru; email: vbeniteszapata@gmail.com},
