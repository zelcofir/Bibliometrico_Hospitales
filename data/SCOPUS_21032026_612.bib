@ARTICLE{Revilla-López2015808,
	author = {Revilla-López, José and Mendoza-Fabián, Raúl and Anampa-Guzmán, Andrea and Rosales-Zúñiga, Josias and Chalco-Huamán, Joel},
	title = {Endemic kaposi’s sarcoma in a hiv-negative patient; [Sarcoma de kaposi endemico en un paciente vih negativo]},
	year = {2015},
	journal = {Revista Peruana de Medicina Experimental y Salud Publica},
	volume = {32},
	number = {4},
	pages = {808 - 812},
	doi = {10.17843/rpmesp.2015.324.1776},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84954442965&doi=10.17843%2Frpmesp.2015.324.1776&partnerID=40&md5=9d01d185a1c3cb04059865ab8cec759e},
	affiliations = {Hospital Nacional Daniel Alcides Carrión, Lima, Peru; Universidad Nacional Mayor de San Marcos, Lima, Peru; Sociedad Científica de San Fernando, Peru},
	abstract = {Kaposi’s sarcoma (KS) is a multicentric, inflammatory angioproliferative cancer associated with herpes virus 8 (HHV-8). It has four clinico-epidemiological types: classic, endemic, iatrogenic and epidemic, or HIV associated. Clinically it may be indolent or aggressive, mainly affecting mucocutaneous areas with eventual visceral and lymph node involvement. It is often present and in a more aggressive form in the HIV-positive population. We report a case of a 27-year-old HIVnegative male patient with a bleeding tumoral lesion in the Waldeyer ring, multiple lymphadenopathies and exophytic foot lesions that remit with anthracycline-based emergency chemotherapy. HIV-negative KS is a rare condition. It is important to consider Peru as an endemic region for HHV-8. The oral involvement of KS is a rare manifestation and of poor prognosis, however, the HIV-negative factor could confer a good prognosis. © 2015, Instituto Nacional de Salud. All rights reserved.},
	author_keywords = {HIV (source: MeSH NLM); Kaposi; Neoplasms; Sarcoma},
	keywords = {Adult; Herpesvirus 8, Human; HIV Infections; Humans; Male; Peru; Sarcoma, Kaposi; anthracycline antibiotic agent; adult; Article; cancer chemotherapy; cancer prognosis; case report; foot disease; human; Kaposi sarcoma; lymphadenopathy; male; complication; Human herpesvirus 8; Human immunodeficiency virus infection; Peru; Sarcoma, Kaposi; virology},
	correspondence_address = {A. Anampa-Guzmán; Lima, Av. Villaverde 308 Urb. San Amadeo de Garagay, Peru; email: andreaangu11@hotmail.com},
	publisher = {Instituto Nacional de Salud},
