@ARTICLE{Malaga2024,
	author = {Malaga, Marco and Aguirre, Rafhael J. and Alva-Diaz, Carlos and Custodio, Nilton and Lanata, Serggio and Montesinos, Rosa and Pintado-Caipa, Maritza},
	title = {Knowledge of dementia and Alzheimer's disease among healthcare professionals in Peru; [Conocimiento sobre demencia y enfermedad de Alzheimer entre profesionales de la salud en Perú]},
	year = {2024},
	journal = {Arquivos de Neuro-Psiquiatria},
	volume = {82},
	number = {9},
	pages = {},
	doi = {10.1055/s-0044-1790576},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85205336208&doi=10.1055%2Fs-0044-1790576&partnerID=40&md5=f003687698e8e2f49091bfaff0fc2459},
	affiliations = {Instituto Peruano de Neurociencias, Unidad de Investigación de Deterioro Cognitivo y Prevención de Demencia, Lima, Peru; Universidad Científica del Sur, Grupo de Investigación Neurociencia, Efectividad Clínica y Salud Pública, Lima, Peru; Universidad Cientifica del Sur, Facultad de Medicina Humana, Lima, Peru; Hospital Daniel Alcides Carrión, Departamento de Medicina, Oficina de Apoyo a la Docencia e Investigación (OADI), Callao, Peru; Universidad Privada San Juan Bautista, Escuela Profesional de Medicina Humana, Lima, Peru; University of California, Weill Institute, Neurosciences, Memory and Aging Center, Department of Neurology, San Francisco, CA, United States; University of California, Global Brain Health Institute, San Francisco, CA, United States},
	abstract = {Background Primary care physicians and other healthcare providers report feeling unprepared to treat persons with dementia (PWD), especially in developing countries Objective We aimed to assess the knowledge of dementia and Alzheimer’s disease (AD) among health professionals in both primary and tertiary care in Peru. Methods We conducted an in-person and virtual survey of healthcare professionals trained in Peru throughout the year 2020. The survey was developed based on a previously published one and reviewed by an expert panel. We compared groups using a Chi-squared test. A Bonferroni corrected p-value of 0.008 was used for statistical significance. Results Out of 804 surveys, we excluded 56 due to incomplete data. A total of 41.6% of respondents were doctors and 21.8%, nurses. One fifth of participants did not recognize AD as a cause of dementia and over half considered “senile dementia” a valid clinical entity. Scores were higher among those with postgraduate training, multiple patients with dementia, or those who had practiced for over 10 years. Conclusion There is a low level of knowledge of dementia and AD among health professionals in Peru, which worsens outside of Lima. Pernicious ideas, such as senile dementia, are still significantly present among respondents. © 2024. The Author(s).},
	author_keywords = {Allied Health Personnel; Alzheimer Disease; Dementia; Peru},
	keywords = {Adult; Alzheimer Disease; Clinical Competence; Dementia; Female; Health Knowledge, Attitudes, Practice; Health Personnel; Humans; Male; Middle Aged; Peru; Surveys and Questionnaires; adult; Alzheimer disease; Article; cross-sectional study; dementia; female; health care personnel; human; human experiment; knowledge; male; multicenter study; nurse; observational study; obstetrician; Peru; physician; psychologist; risk factor; senile dementia; tertiary health care; attitude to health; clinical competence; middle aged; psychology; questionnaire},
	correspondence_address = {N. Custodio; Instituto Peruano de Neurociencias, Unidad de Investigación de Deterioro Cognitivo y Prevención de Demencia, Lima, Peru; email: nilton.custodio@upsjb.edu.pe},
	publisher = {Associacao Arquivos de Neuro-Psiquiatria},
