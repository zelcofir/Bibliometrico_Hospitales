	title = {Paradoxical cerebral embolism due to transiently patent foramen ovale as a complication of massive pulmonary thromboembolism: Case Report; [Embolia cerebral paradójica por foramen oval temporal como complicación de tromboembolismo pulmonar masivo: reporte de caso]},
	year = {2024},
	journal = {Acta Medica Peruana},
	volume = {41},
	number = {1},
	pages = {53 - 57},
	doi = {10.35663/amp.2024.411.2755},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85196768800&doi=10.35663%2Famp.2024.411.2755&partnerID=40&md5=3c2871b9ad2ec58bed08ad2b2f84fae9},
	affiliations = {Hospital Daniel Alcides Carrión EsSalud, Tacna, Peru},
	abstract = {Paradoxical cerebral embolism always requires the presence of a patent foramen ovale (PFO); in our case, this event occurred due to a transient phenomenon, which was the acute overload of the right heart chambers and the opening of the PFO due to increased pressures as a consequence of massive pulmonary thromboembolism. After undergoing arthroscopy, this patient presented with visual field loss and progressive dyspnea, ultimately leading to mechanical ventilation and severe obstructive shock. An angiotomography was performed, revealing an obstructive thrombus in the right pulmonary artery. The patient successfully underwent thrombolysis, and she was discharged from the intensive care unit after 45 days. Ultimately, protein C deficiency was diagnosed, and permanent anticoagulation was initiated. The presence of motor deficit and dyspnea in a post-knee surgery patient should raise suspicion of pulmonary thromboembolism. Thrombolysis remains the treatment of choice, and it should be timely prescribed and performed. © 2024 Colegio Medico del Peru. All rights reserved.},
	author_keywords = {Embolism; Foramen Ovale; Paradoxical; Patent (Source: MeSH-NLM); Pulmonary Embolism},
	keywords = {anticoagulation; artery thrombosis; arthroscopy; Article; artificial ventilation; blood clot lysis; brain embolism; case report; clinical article; dyspnea; female; heart foramen ovale; hospital discharge; human; intensive care unit; knee surgery; patent foramen ovale; Peru; protein C deficiency; right pulmonary artery; visual impairment},
	correspondence_address = {R.J.F. Palacios; Hospital Daniel Alcides Carrión EsSalud, Tacna, Peru; email: rflores@unjbg.edu.pe},
	publisher = {Colegio Medico del Peru},
	issn = {10188800},
