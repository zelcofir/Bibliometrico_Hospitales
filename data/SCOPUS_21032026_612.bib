	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85020044072&doi=10.1093%2Fcid%2Fcix039&partnerID=40&md5=a0a627cbadbdd942360cea58b818d027},
	affiliations = {Facultad de Medicina Alberto Hurtado, Universidad Peruana Cayetano Heredia, Av. El Mastil 387 Apt 602-I Las Lagunas, La Molina, Lima, Peru; Laboratorio de Investigación en Enfermedades Infecciosas, Laboratorio de Investigación y Desarrollo, Facultad de Ciencias y Filosofía, Universidad Peruana Cayetano Heredia, Peru; Asociación Benéfica PRISMA, Lima, Peru; Department of General Internal Medicine, Massachusetts General Hospital, Boston, United States; Innovation for Health and Development, Laboratory of Research and Development, United States; Laboratorio de Bioinformática y Biología Molecular, Facultad de Ciencias y Filosofía, Universidad Peruana Cayetano Heredia, Peru; Instituto Nacional de Salud Del Niño San Borja, Lima, Peru; Department of Global Community Health and Behavioral Sciences, Tulane University, New Orleans, United States; Division of Epidemiology and Biostatistics, Mel and Enid Zuckerman College of Public Health, University of Arizona, Tucson, United States; Infectious Diseases and Immunity, Wellcome Trust Imperial College, Centre for Global Health Research, Imperial College London, United Kingdom; Escuela Profesional de Ingeniería Física, Facultad de Ciencias, Universidad Nacional de Ingeniería, Peru; Servicio de Neumología, Hospital Nacional Alcides Carrión, Peru; Servicio de Neumología, Hospital Nacional Dos de Mayo, Peru; Facultad de Medicina, Universidad Nacional Mayor de San Marcos, Peru; Servicio de Enfermedades Infecciosas y Tropicales, Hospital Nacional Dos de Mayo, Lima, Peru; Department of Internal Medicine, Cleveland Clinic, OH, United States; Tuberculosis Centre, London School of Hygiene and Tropical Medicine, United Kingdom; Department of Electrical and Computer Engineering, Tufts University, Medford, MA, United States; Program in Global Disease Epidemiology and Control, Department of International Health, Bloomberg School of Public Health, Johns Hopkins University, Baltimore, United States},
	abstract = {Background. Cough is the major determinant of tuberculosis transmission. Despite this, there is a paucity of information regarding characteristics of cough frequency throughout the day and in response to tuberculosis therapy. Here we evaluate the circadian cycle of cough, cough frequency risk factors, and the impact of appropriate treatment on cough and bacillary load. Methods. We prospectively evaluated human immunodeficiency virus-negative adults (n = 64) with a new diagnosis of culture- proven, drug-susceptible pulmonary tuberculosis immediately prior to treatment and repeatedly until treatment day 62. At each time point, participant cough was recorded (n = 670) and analyzed using the Cayetano Cough Monitor. Consecutive coughs at least 2 seconds apart were counted as separate cough episodes. Sputum samples (n = 426) were tested with microscopic-observation drug susceptibility broth culture, and in culture-positive samples (n = 252), the time to culture positivity was used to estimate bacillary load. Results. The highest cough frequency occurred from 1 pm to 2 pm, and the lowest from 1 am to 2 am (2.4 vs 1.1 cough episodes/ hour, respectively). Cough frequency was higher among participants who had higher sputum bacillary load (P < .01). Pretreatment median cough episodes/hour was 2.3 (interquartile range [IQR], 1.2-4.1), which at 14 treatment days decreased to 0.48 (IQR, 0.0- 1.4) and at the end of the study decreased to 0.18 (IQR, 0.0-0.59) (both reductions P < .001). By 14 treatment days, the probability of culture conversion was 29% (95% confidence interval, 19%-41%). Conclusions. Coughs were most frequent during daytime. Two weeks of appropriate treatment significantly reduced cough frequency and resulted in one-third of participants achieving culture conversion. Thus, treatment by 2 weeks considerably diminishes, but does not eliminate, the potential for airborne tuberculosis transmission. © The Author 2017. Published by Oxford University Press for the Infectious Diseases Society of America.},
	author_keywords = {Airborne transmission; Cough; Infectiousness; Peru; Tuberculosis},
	keywords = {Adolescent; Adult; Aged; Aged, 80 and over; Antitubercular Agents; Circadian Rhythm; Cough; Female; Humans; Longitudinal Studies; Male; Middle Aged; Prospective Studies; Tuberculosis, Pulmonary; Young Adult; tuberculostatic agent; tuberculostatic agent; antibiotic sensitivity; Article; bacterial load; bacterial transmission; bacterium culture; circadian rhythm; cohort analysis; confidence interval; coughing; female; human; lung tuberculosis; major clinical study; male; monitor; Mycobacterium; priority journal; probability; prospective study; risk factor; sputum smear; adolescent; adult; aged; coughing; longitudinal study; lung tuberculosis; middle aged; pathology; very elderly; young adult},
	correspondence_address = {A. Proaño; Facultad de Medicina Alberto Hurtado, Universidad Peruana Cayetano Heredia, Lima, Av. El Mastil 387 Apt 602-I Las Lagunas, La Molina, Peru; email: alvaro.proano.f@upch.pe},
	publisher = {Oxford University Press},
