@ARTICLE{Torres2013575,
	author = {Torres, Nancy and Velásquez, Ricardo and Mercado, Erik H. and Egoavil, Martha and Horna, Gertrudis and Mejía, Lida and Castillo, María E. and Chaparro, Eduardo and Hernández, Roger and Silva, Wilda and Campos, Francisco E. and Sáenz, Andrés and Hidalgo, Félix and Letona, Carolina and Valencia, Ángel G. and Cerpa, Rosario and López-de-Romaña, Bernardo and Torres, Berenice and Castillo, Fiorella and Calle, Andrea and Rabanal, Synthia and Pando, Jackeline and Lacroix, Elizabeth and Reyes, Isabel and Guerra, Humberto and Ochoa, Theresa J.},
