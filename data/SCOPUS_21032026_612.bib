@ARTICLE{Virú-Loza2014530,
	author = {Virú-Loza, Manuel A. and Palacios-Guillén, Alaciel Melissa},
	title = {Hyperuricemia and progression of chronic cardiorenal compromise; [Hiperuricemia y progresión del compromiso cardiorrenal crónico]},
	year = {2014},
	journal = {Revista Peruana de Medicina Experimental y Salud Publica},
	volume = {31},
	number = {3},
	pages = {530 - 534},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84922718842&partnerID=40&md5=964a8190eb13759324cc2ff4ae479710},
	affiliations = {Universidad Nacional Mayor de San Marcos, Lima, Peru; Asociación para el Desarrollo de la Investigación Estudiantil en Ciencias de la Salud (ADIECS-UNMSM), Lima, Peru; Hospital Nacional Daniel Alcides Carrión, Callao, Peru},
	abstract = {In order to determine whether hyperuricemia is associated with the progression of chronic cardiorenal compromise (CCC), a retrospective cohort study was performed which included 103 patients in whom CCC was defined as the simultaneous presence of chronic kidney disease (CKD) and chronic heart disease (CHD). CKD progression was defined as a 50% reduction of glomerular filtration rate estimated by the MDRD-4 equation. Hyperuricemia was defined as basal levels of uric acid ≥ 7 mg/dL. None of the studied variables showed association with the progression of CCC or CHD. Independent predictors of CKD progression were basal hyperuricemia (HR 4.41, 95% CI: 1.02-18.94) and SAP in followup (HR 1.05, 95% CI: 1.01-1.09). We conclude that hyperuricemia is an independent risk factor for the progression of CKD in patients with CCC. © 2014, Instituto Nacional de Salud. All rights reserved.},
	author_keywords = {Arterial pressure; Cardio-renal syndrome; Chronic; Disease progression; Follow-up studies; Hyperuricemia; Renal insufficiency; Uric acid},
