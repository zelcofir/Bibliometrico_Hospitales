@ARTICLE{Urure Velazco2025,
	author = {Urure Velazco, Isabel Natividad and Pacheco Villa García, Luisa Antonia and Llerena Ururi, Karen Leticia and Berrocal Pacheco, Pedro Luis},
	title = {Perceived satisfaction and humanized nursing care in surgical patients public hospital of Peru; [Satisfacción percibida y cuidado humanizado de enfermería en pacientes quirúrgicos en un hospital público del Perú]},
	year = {2025},
	journal = {Enfermeria Clinica},
	volume = {35},
	number = {1},
	pages = {},
	doi = {10.1016/j.enfcli.2024.06.008},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85201681166&doi=10.1016%2Fj.enfcli.2024.06.008&partnerID=40&md5=1919278c7a9c9a91d6f54d5a5c44f4bf},
	affiliations = {Universidad Nacional San Luis Gonzaga, Facultad de Enfermería, Ica, Peru; Hospital Santa María del Socorro, Ica, Peru; Hospital Regional de Ica, Ica, Peru; Hospital Regional Honorio Delgado Espinoza, Arequipa, Peru; Consorcio Señor de Locumba II, Ica, Peru},
	abstract = {Introduction: Humanized care is the first aspect to consider to satisfy the surgical patient who will be or has undergone a surgical intervention. Objetive: Determine the relationship that exists between perceived satisfaction and humanized nursing care in surgical patients in a public hospital in Peru. Method: Descriptive, observational, correlational study, with a quantitative approach, with probabilistic sampling of 241 surgical patients. A validated questionnaire adapted to our reality was used, reporting a Cronbach Alpha coefficient of 0.890 (satisfaction) and 0.904 (humanized nursing care), presenting 36 multiple choice questions. Results: The age group of 18-29 years predominated in 26.6% (n = 64), with the average age X = 42.6 years with a DS of 14.47, female sex with 55.2% (n = 133), single marital status 48.5% (n = 117) and secondary education level was 60.2% (n = 145). The majority of patients were satisfied with the care received, reporting 84.6% (n = 204), also found in the dimensions: Humane 81.8% (n = 197), timely 78.8% (n = 190) and safe 80.1% (n = 193). The perceived humanized nursing care was good 81.3% (n = 196), it was also evident in the dimensions: Phenomenological 78.4% (n = 189), interaction 75.9% (n = 183), scientific 61, 8% (n = 149) and human needs (82.2%) (n = 198). Conclusions: A moderate correlation was found between the variables, behaving in a moderately positive manner, that is, the higher the level of satisfaction, the higher the level of humanized nursing care in the surgical patient, and vice versa. © 2024 The Authors},
	author_keywords = {Nursing; Patient satisfaction; Surgical care},
	keywords = {adult; aged; article; complication; controlled study; correlational study; Cronbach alpha coefficient; cross-sectional study; female; human; major clinical study; male; multiple choice test; nursing care; observational study; patient satisfaction; Peru; public hospital; questionnaire; satisfaction; secondary education; single (marital status); surgery; surgical patient},
	correspondence_address = {I.N. Urure Velazco; Universidad Nacional San Luis Gonzaga, Facultad de Enfermería, Ica, Peru; email: iurure@unica.edu.pe},
	publisher = {Elsevier Espana S.L.U},
	issn = {11308621},
	language = {English},
	abbrev_source_title = {Enferm. Clin.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Hybrid Gold Open Access}
}

