	keywords = {Guillain-Barre Syndrome; Humans; Latin America; Respiration, Artificial; Respiratory Insufficiency; Retrospective Studies; artificial ventilation; Guillain Barre syndrome; human; respiratory failure; retrospective study; South and Central America},
	correspondence_address = {C. Alva-Diaz; Facultad de Ciencias de la Salud, Universidad Científica del Sur, Lima, Peru; email: carlos.alexander.alva@gmail.com},
