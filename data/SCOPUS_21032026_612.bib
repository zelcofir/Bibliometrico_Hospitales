@ARTICLE{Gamonal2024,
	author = {Gamonal, Bryan and Quispe-Lizano, Rogelio and Javier-Murillo, Nair and Lapeyre-Rivera, André and Perea-Flórez, Francisco and Velásquez-Rimachi, Víctor and Alva-Diaz, Carlos and Velazco-Gonzales, Gilberth and Ahmed, Oli and Chung, Seockhoon},
