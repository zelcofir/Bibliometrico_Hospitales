	correspondence_address = {B. Gamonal; Facultad de Medicina Humana, Universidad de Piura, Lima, Peru; email: bryan.gamonal@alum.udep.edu.pe; S. Chung; Department of Psychiatry, Asan Medical Center, University of Ulsan College of Medicine, Seoul, South Korea; email: schung@amc.seoul.kr},
