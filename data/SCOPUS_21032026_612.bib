	volume = {33},
	pages = {},
	doi = {10.1590/1980-265X-TCE-2023-0294en},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85199981529&doi=10.1590%2F1980-265X-TCE-2023-0294en&partnerID=40&md5=da1baf5d4c646a0d66513be6142905e3},
	affiliations = {Universidade Federal de Santa Catarina, Programa de Pós-Graduação em Enfermagem., Santa Catarina, Florianópolis, Brazil; University of Helsinki, Faculty of Social Sciences, Center for Social Data Science, Helsinki, Finland; Rede de Enfermagem de Emergências e Desastres das Américas, São Paulo, São Paulo, Brazil; Universidad Peruana Cayetano Heredia, Hospital Nacional Daniel Alcides Carrión, Lima, Peru; Universidade Federal do Ceará, Ceará, Fortaleza, Brazil},
	abstract = {Objective: to identify courses available online by national civil defense bodies in Brazil and Mexico to assist in the additional training of healthcare professionals for disasters. Method: an exploratory descriptive study, based on a qualitative approach, using technological prospecting methodology, carried out on the official Civil Defense websites in Brazil and Mexico. Results: ten courses offered by the Government of Mexico’s National Center for Disaster Prevention were found, nine of which were short-term and one offered as vocational training. All of these courses were synchronous. In Brazil, 36 courses were located, all in asynchronous formats, with durations varying between 20 and 50 hours. Although the courses presented programmatic content that included activities inherent to healthcare professionals, none of them made specific mention of professionals in this area as the target audience. Conclusion: the prospective study reinforces that Information and Communication Technologies for distance education present themselves as an alternative present in both countries in terms of additional training for disasters, although not yet specifically aimed at healthcare professionals. The need to include this area of interdisciplinary and multi-professional content reflects gaps in sector integration. © 2024, Universidade Federal de Santa Catarina. All rights reserved.},
	author_keywords = {Disaster Risk Reduction; Education in Disasters; Education, Distance; Education, Nursing; Information Technology},
	keywords = {article; Brazil; civil defense; digital technology; disaster; disaster mitigation; distance learning; duration; education; female; government; health care personnel; human; information technology; Mexico; nursing education; prevention; prospective study; training; vocational education},
