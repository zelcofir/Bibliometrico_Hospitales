	affiliations = {Hepatology and Liver Transplant Unit, Hospital Universitario Austral, Universidad Austral, Pilar, Argentina; Latin American Liver Research Educational and Awareness Network (LALREAN); Liver Section, Centro de Educación Médica e Investigaciones Clínicas, Buenos Aires, Argentina; Hepatology and Liver Transplant Unit, Hospital Alemán, Buenos Aires, Argentina; Gastroenterology Unit, Hospital Nacional Guillermo Almenara Irigoyen, Lima, Peru; Hepatology and Liver Transplant Unit, Hospitales de San Vicente Fundación de Medellín y Rionegro, Medellín, Colombia; Department of Gastroenterology, Instituto Nacional de Ciencias Médicas y Nutrición, Ciudad de México, Mexico; Gastroenterology Unit, Hospital Nacional Daniel A. Carrión, Callao, Peru; Gastroenterology Section, Internal Medicine Department, Hospital Clínico de la Universidad de Chile, Santiago, Chile; Department of Gastroenterology, Hospital de Clínicas José de San Martín, Universidad de Buenos Aires, Buenos Aires, Argentina; Department of Internal Medicine, Sanatorio Anchorena, Buenos Aires, Argentina; Hospital Especializado en Enfermedades Infecciosas Instituto Couto Maia, Salvador de Bahía, Brazil; Hospital Nacional Edgardo Rebagliati Martins, Lima, Peru; Intensive Care Unit, Hospital de Infecciosas Francisco J Muñiz, Buenos Aires, Argentina; Gastroenterology Unit, Hospital de Víctor Lazarte Echegaray, Trujillo, Peru; Department of Internal Medicine, Centro Médico ABC, Ciudad de México, Mexico; Department of Medicine, IMSS Hospital General Regional No. 1 “Dr. Carlos Mc Gregor Sánchez”, Ciudad de México, Mexico; Department of Gastroenterology, Hospital Italiano de La Plata, La Plata, Argentina; Medica Sur Clinic & Foundation, Ciudad de México, Mexico; Gastroenterology Unit, Clínica Anglo-Americana, Lima, Peru; Department of Gastroenterology, Hospital Padre Hurtado, Santiago, Chile; Liver Unit, Fundación Cardio-Infantil, Bogotá, Colombia; Hospital Regional Dr. Teodoro Maldonado Carbo del IESS, Guayaquil, Ecuador; Department of Gastroenterology and Hepatology, Hospital General de México “Dr. Eduardo Liceaga”, Ciudad de México, Mexico; Gastroenterology Unit, Clínica Delgado, Lima, Peru; Unidad de Hígado, Hospital Privado de Córdoba, Córdoba, Argentina; Gastroenterology Unit, Hospital Nacional Almanzor Aguinaga Asenjo, Chiclayo, Peru; Endoscopy and Transplant Service, Hospital Universitario Fundación Santa Fe de Bogotá, Bogotá, Colombia; Gastroenterology Unit, Hospital de Especialidades del Centro Médico Nacional La Raza IMSS, Ciudad de México, Mexico; Department of Gastroenterology, Hospital Alianza, Bahía, Brazil; Department of Gastroenterology, Hospital Provincial del Centenario, Rosario, Argentina; Department of Gastroenterology, CEDIMAT, Santo Domingo, Dominican Republic; Department of Gastroenterology, Clínica Las Condes, Santiago, Chile; Department of Gastroenterology, Hospital Roosevelt, Ciudad de Guatemala, Guatemala; Instituto de Efectividad Clínica y Sanitaria, Buenos Aires, Argentina},
	abstract = {Introduction and Objectives: Viral infections have been described to increase the risk of decompensation in patients with cirrhosis. We aimed to determine the effect of SARS-CoV-2 infection on outcome of hospitalized patients with cirrhosis and to compare the performance of different prognostic models for predicting mortality. Patients: We performed a prospective cohort study including 2211 hospitalized patients with confirmed SARS-CoV-2 infection from April 15, 2020 through October 1, 2020 in 38 Hospitals from 11 Latin American countries. We registered clinical and laboratory parameters of patients with and without cirrhosis. All patients were followed until discharge or death. We evaluated the prognostic performance of different scoring systems to predict mortality in patients with cirrhosis using ROC curves. Results: Overall, 4.6% (CI 3.7–5.6) subjects had cirrhosis (n = 96). Baseline Child-Turcotte-Pugh (CTP) class was assessed: CTP-A (23%), CTP-B (45%) and CTP-C (32%); median MELD-Na score was 19 (IQR 14−25). Mortality was 47% in patients with cirrhosis and 16% in patients without cirrhosis (P <.0001). Cirrhosis was independently associated with death [OR 3.1 (CI 1.9−4.8); P <.0001], adjusted by age, gender, and body mass index >30. The areas under the ROC curves for performance evaluation in predicting 28-days mortality for Chronic Liver Failure Consortium (CLIF-C), North American Consortium for the Study of End-Stage Liver Disease (NACSELD), CTP score and MELD-Na were 0.85, 0.75, 0.69, 0.67; respectively (P <.0001). Conclusions: SARS-CoV-2 infection is associated with elevated mortality in patients with cirrhosis. CLIF-C had better performance in predicting mortality than NACSELD, CTP and MELD-Na in patients with cirrhosis and SARS-CoV-2 infection. Clinicaltrials.gov:NCT04358380. © 2021 Fundación Clínica Médica Sur, A.C.},
	author_keywords = {Acute-on-chronic liver failure; Cirrhosis; Coronavirus; COVID-19; Death; Pandemic},
