	title = {Unveiling the Link Between Antiphospholipid Antibodies and Cognitive Dysfunction in the Almenara Lupus Cohort},
	year = {2024},
	journal = {Journal of Clinical Rheumatology},
	volume = {30},
	number = {2},
	pages = {41 - 45},
	doi = {10.1097/RHU.0000000000002049},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85185614757&doi=10.1097%2FRHU.0000000000002049&partnerID=40&md5=31f2b1d805bb41cbaabb11bd3776ed9d},
	affiliations = {The Hospital Nacional Carlos Alberto Seguin Escobedo, EsSalud, Arequipa, Peru; Hospital Nacional Guillermo Almenara Irigoyen, EsSalud, Peru; Grupo Peruano de Estudio de Enfermedades Autoinmunes Sistémicas, Universidad Científica del Sur, Peru; School of Medicine, Universidad Nacional Mayor de San Marcos, Lima, Peru; Max E. Heersink School of Medicine, The University of Alabama at Birmingham, Birmingham, AL, United States; School of Medicine, Universidad Peruana Cayetano Heredia, Lima, Peru},
	abstract = {Objective: Cognitive dysfunction is a prevalent manifestation of systemic lupus erythematosus (SLE). There is evidence for the role of antiphospholipid (aPL) antibodies on its etiopathogenesis. Our objective was to identify the association between aPL antibodies and cognitive dysfunction in SLE patients. Methods: This cross-sectional study included 135 patients evaluated from March 2015 to October 2017 at one center. Cognitive deficit was measured using the NEUROPSI test. Disease activity and damage were ascertained using the SLEDAI-2K (SLE Disease Activity Index 2000) and the SDI (Systemic Lupus International Collaborating Clinics/American College of Rheumatology Damage Index), respectively; aPL antibodies were measured by enzyme-linked immunosorbent assay. The association between cognitive dysfunction and aPL antibodies was evaluated using univariable and multivariable linear regression models adjusted for age, sex, education, socioeconomic status, disease duration, SLEDAI-2K, SDI, mean current dose of prednisone, time of exposure to glucocorticoids, and drug use (immunosuppressants, hydroxychloroquine, aspirin, and warfarin). Results: One hundred thirty-one patients (97.1%) were women; their mean (SD) age was 46.6 (12.5) years; 59 patients (43.7%) had positivity for at least 1 aPL antibody. IgM anticardiolipin (aCL) was positive in 24.5%, IgG in 13.5%, IgM aβ2GP1 in 16.8%, IgG anti-β2 glycoprotein in 24.6%, and the lupus anticoagulant in 5.3%. Ninety patients (66.7%) had some cognitive dysfunction. In the univariable analysis, a significant correlation between the NEUROPSI score and IgM aCL antibodies was found (B = −20.87 [SE, 3.2]; p < 0.001), which remained significant in the multivariable model (B = −13.89 [SE, 3.14]; p < 0.001). Conclusions: IgM aCL antibodies are associated with cognitive dysfunction in patients with SLE. Larger and longitudinal studies are needed to assess the impact of these findings. Copyright © 2023 Wolters Kluwer Health, Inc. All rights reserved.},
	keywords = {Antibodies, Anticardiolipin; Antibodies, Antiphospholipid; Antiphospholipid Syndrome; Cognitive Dysfunction; Cross-Sectional Studies; Female; Humans; Immunoglobulin G; Immunoglobulin M; Lupus Erythematosus, Systemic; Male; Middle Aged; acetylsalicylic acid; azathioprine; beta2 glycoprotein 1 antibody; cardiolipin antibody; cyclophosphamide; cyclosporine; glucocorticoid; hydroxychloroquine; immunoglobulin G; immunoglobulin G antibody; immunoglobulin M; immunoglobulin M antibody; lupus anticoagulant; methotrexate; mycophenolate mofetil; phospholipid antibody; prednisone; rituximab; warfarin; cardiolipin antibody; immunoglobulin G; immunoglobulin M; phospholipid antibody; adult; age; aged; Article; cognitive defect; cohort analysis; cross-sectional study; disease association; disease duration; educational status; enzyme linked immunosorbent assay; female; human; immunosuppressive treatment; longitudinal study; major clinical study; male; mild cognitive impairment; NEUROPSI score; scoring system; sex; SLEDAI; social status; systemic lupus erythematosus; antiphospholipid syndrome; cognitive defect; complication; middle aged},
	correspondence_address = {Y. Velarde-Mejía; Hospital Nacional Carlos Alberto Seguin Escobedo, Universidad Catolica de Santa Maria, Arequipa, Ramon Castilla St 755, Miraflores District, 04004, Peru; email: ginger12887@outlook.com},
