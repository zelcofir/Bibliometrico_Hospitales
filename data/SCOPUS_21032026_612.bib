@ARTICLE{Custodio2016652,
	author = {Custodio, Nilton and Alva-Diaz, Carlos and Becerra-Becerra, Yahaira and Montesinos, Rosa and Lira, David and Herrera-Pérez, Eder and Castro-Suárez, Sheila and Cuenca-Alfaro, José and Valeriano-Lorenzo, Elizabeth},
	title = {Performance of cognitive brief test in elderly patients with dementia in advanced stage living in an urban community of Lima, Peru; [Rendimiento en pruebas cognitivas breves, de adultos mayores con demencia en estadios avanzados, residentes de una comunidad urbana De Lima, Perú]},
	year = {2016},
	journal = {Revista Peruana de Medicina Experimental y Salud Publica},
	volume = {33},
	number = {4},
	pages = {652 - 669},
	doi = {10.17843/rpmesp.2016.334.2549},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85013393330&doi=10.17843%2Frpmesp.2016.334.2549&partnerID=40&md5=32e74fc0a147cdf3350515ebaeaea973},
	affiliations = {Servicio de Neurología, Instituto Peruano de Neurociencias, Lima, Peru; Servicio de Neurología, Clínica Internacional, Lima, Peru; Servicio de Neurología, Hospital Nacional Daniel Alcides Carrión, Callao, Peru; Servicio de Geriatría, Hospital Militar Geriátrico, Lima, Peru; Red de Eficacia Clínica y Sanitaria REDECS, Lima, Peru; Unidad de Medicina de Rehabilitación, Instituto Peruano de Neurociencias, Lima, Peru; Unidad de Proyectos de Investigación, Instituto de Salud del Niño, Lima, Peru; Servicio de Neurología de la Conducta, Instituto Nacional de Ciencias Neurológicas, Lima, Peru; Unidad de Neuropsicología, Instituto Peruano de Neurociencias, Lima, Peru},
	abstract = {Objectives. Evaluate the performance of clock drawing test- Manos versión (PDR-M) and Mini Mental State Examination - Peruvian version (MMSE) to detect dementia in a sample based on urban community of Lima, Peru. Materials and methods. This study is a secondary analysis database, observational, analytical and cross-sectional, the gold standard was the clinical and the neuropsychological evaluations together. Performance testing individually and in combination were evaluated.. Data were obtained from prevalence study conducted in 2008 in Cercado de Lima. Results. MMSE performance for evaluation of patients with dementia of any kind showed sensitivity of 64,1%, specificity of 84,1%, PPV of 24.4%, NPV of 96.7%, PLR of 4,03 and NLR of 0,43. PDR-M showed sensitivity of 89,3%, specificity of 98,1%, PPV of 79.3%, NPV of 99.1%, PLR of 47,79 and NLR of 0,11. When both tests were applied, and at least one of them was positive, they showed sensitivity 98.1%, specificity 84.1%, PPV of 33.1%, NPV of 99.8%, PLR of 6,17 and NLR of 0,02. When performing separate analysis of Alzheimer-type dementia and non- Alzheimer dementia, the values of the parameters do not differ substantially from those obtained for dementia of any kind. Conclussions. The combination of MMSE and PDR-M show good discriminative ability to detect moderate and severe dementia in population living in urban community in Lima. © 2016, Instituto Nacional de Salud. All rights reserved.},
	author_keywords = {Alzheimer’s disease; Dementia; Diagnostic Techniques; Differential diagnosis; Neurological (source: MeSH NLM); Sensitivity and Specificity},
	keywords = {Aged; Cognition; Cross-Sectional Studies; Dementia; Female; Humans; Male; Neuropsychological Tests; Peru; Sensitivity and Specificity; aged; aging; Alzheimer disease; Article; clinical assessment; clinical evaluation; cognitive function test; cross-sectional study; dementia; discriminant analysis; disease severity; gold standard; human; Mini Mental State Examination; neuropsychological test; observational study; performance; performance of clock drawing test Manos version; Peru; predictive value; prevalence; sensitivity and specificity; urban population; cognition; dementia; female; male; neuropsychological test},
	correspondence_address = {N. Custodio; Unidad de Investigación, Instituto Peruano de Neurociencias, Lince, Bartolomé Herrera 161, Peru; email: ncustodio@ipn.pe},
