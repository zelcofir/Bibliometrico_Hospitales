@ARTICLE{Miranda-Corrales2025331,
	author = {Miranda-Corrales, Miriam Elizabeth and Begazo-Paredes, Joselyn Elizabeth and Garcia-Tejada, Barbara Alejandra and Alvarez-Cervantes, Giancarlo and Sulla-Torres, Jose Alfredo and Beltran, Herbert Jesus Del Carpio and Benites-Meza, Jerry K. and Munoz-del-Carpio-Toia, Agueda},
	title = {History of COVID-19 as a Risk Factor for Cardiac Arrhythmias: A Case-Control Study},
	year = {2025},
