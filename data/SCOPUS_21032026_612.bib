	title = {COMPLEMENTARY TRAINING IN DISASTERS FOR HEALTHCARE PROFESSIONALS: AN ANALYSIS OF THE OFFICIAL OFFER IN BRAZIL AND MEXICO; [FORMAÇÃO COMPLEMENTAR EM DESASTRES PARA PROFISSIONAIS DA SAÚDE: UMA ANÁLISE DA OFERTA OFICIAL NO BRASIL E MÉXICO]; [FORMACIÓN COMPLEMENTARIA EN DESASTRES PARA PROFESIONALES DE LA SALUD: UN ANÁLISIS DE LA OFERTA OFICIAL EN BRASIL Y MÉXICO]},
	year = {2024},
