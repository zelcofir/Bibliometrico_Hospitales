@ARTICLE{Lombardi2019,
	author = {Lombardi, Raúl and Ferreiro, Alejandro and Granado, Rolando Claure-Del and Burdmann, Emmanuel A. and Rosa-Diez, Guillermo and Yu, Luis and Younes-Ibrahim, Mauricio and Carlino, Cristina and Chávez-Iñiguez, Jonathan S. and Pereira, Mariana B. and Varela, Carlos F. and Zamoner, Welder and Janiques, Diego and Lecueder, Soledad and Cerrón-Millán, Víctor and Cueto-Manzano, Alfonso},
	title = {EPILAT-IRA study: A contribution to the understanding of the epidemiology of acute kidney injury in Latin America},
